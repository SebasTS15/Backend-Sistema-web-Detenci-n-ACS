APP_NAME=Backend Tesis Apnea
APP_ENV=development

# Ruta del modelo entrenado
MODEL_PATH=./modelo_resnet_apnea_central_0-7.pth
MODEL_THRESHOLD=0.5

# PostgreSQL local
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tesis_apnea
DB_USER=postgres
DB_PASSWORD=postgres

# JWT y autenticación
JWT_SECRET_KEY=change_me_with_a_secure_secret
AUTH_USERNAME=admin
AUTH_PASSWORD=admin
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60

# CORS: separa origenes con coma. Usa * solo en desarrollo.
CORS_ORIGINS=*
